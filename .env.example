# ── Required ──────────────────────────────────────────────
# Get your key at https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Admin dashboard credentials
ADMIN_USER=admin
ADMIN_PASS=change_me_to_a_strong_password

# ── Optional ──────────────────────────────────────────────
# Publicly accessible URL of this app (used in OpenRouter HTTP-Referer header)
APP_URL=http://localhost:3000

# Comma-separated list of allowed CORS origins (defaults to APP_URL / localhost)
ALLOWED_ORIGINS=http://localhost:3000

# Override the AI models used for routing (defaults shown)
MODEL_FAST=openai/gpt-4o-mini
MODEL_SMART=openai/gpt-4o

# n8n webhook URL (optional — app falls back to direct OpenRouter if not set)
N8N_WEBHOOK_URL=http://localhost:5678/webhook/cyber-chat

# ── Database (pick one) ───────────────────────────────────
# Option A: Full connection string (Railway / cloud Postgres)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Option B: Individual params (local Docker Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_USER=cyber
DB_PASSWORD=
DB_NAME=cyber_chatbot

# Server port (Railway sets this automatically)
PORT=3000
